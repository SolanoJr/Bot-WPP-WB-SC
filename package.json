{
  "name": "bot-wpp",
  "version": "1.0.0",
  "description": "Bot de WhatsApp com IA e Comandos",
  "main": "dist/core/index.js",
  "type": "commonjs",
  "scripts": {
    "dev:relay": "tsx watch src/relay/server.ts",
    "build": "npm run build:relay && npm run build:services && npm run build:bot && npm run build:main && npm run build:core",
    "build:relay": "tsup src/relay/server.ts --out-dir dist/relay --format cjs",
    "build:services": "tsup src/services/*.ts --out-dir dist/services --format cjs",
    "build:bot": "tsup src/bot/index.ts src/bot/config.ts src/bot/customCommands.ts src/bot/relayClient.ts src/bot/commands/*.ts --out-dir dist/bot --format cjs",
    "build:main": "tsup src/whatsapp.ts --out-dir dist --format cjs",
    "build:core": "tsup src/core/index.ts --out-dir dist/core --format cjs",
    "start": "node dist/relay/server.js",
    "bot:start": "node dist/core/index.js",
    "test": "vitest run",
    "test-commands": "node test_commands.js",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.x"
  },
  "keywords": [],
  "author": "WarriorBlack",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "nodemon": "^3.1.7",
    "qrcode-terminal": "^0.12.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "whatsapp-web.js": "^1.34.7",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^6.0.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
